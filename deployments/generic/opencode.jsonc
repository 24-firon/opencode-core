{
  "$schema": "https://opencode.ai/config.json",

  "snapshot": false,

  "watcher": {
    "ignore": [
      "**/node_modules/**",
      "**/.git/**",
      "**/dist/**",
      "**/build/**",
      "**/__pycache__/**",
      "**/.venv/**",
      "**/.claude/**",
      "**/.cursor/**",
      "**/.roo/**",
      "**/.agents/**",
      "**/.windsurf/**",
      "**/.aider/**",
      "**/.continue/**",
      "**/.codeium/**",
      "**/.tabnine/**",
      "**/.copilot/**",
      "**/.gemini/**",
      "**/.opencode-agent/**",
      "**/.cline/**",
      "**/.kilocode/**",
      "**/.qoder/**",
      "**/.github-copilot/**",
      "**/.codewhisperer/**",
      "**/.sourcegraph/**",
      "**/.supermaven/**",
      "**/.void/**",
      "**/.pearai/**",
      "**/.trae/**",
      "**/.replit-agent/**",
      "**/.zed/**",
      "**/.nova/**",
      "**/.phantom/**"
    ]
  },

  "instructions": [
    ".opencode/rules/*.md"
  ],

  "permission": {
    "bash": "ask",
    "edit": "ask",
    "webfetch": "allow"
  }
}
