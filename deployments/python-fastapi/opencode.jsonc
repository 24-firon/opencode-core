{
  "$schema": "https://opencode.ai/config.json",

  "snapshot": false,

  "watcher": {
    "ignore": [
      "**/.git/**",
      "**/__pycache__/**",
      "**/.venv/**",
      "**/venv/**",
      "**/.ruff_cache/**",
      "**/.mypy_cache/**",
      "**/.pytest_cache/**",
      "**/dist/**",
      "**/build/**",
      "**/*.egg-info/**",
      "**/.claude/**",
      "**/.cursor/**",
      "**/.roo/**",
      "**/.agents/**",
      "**/.windsurf/**",
      "**/.aider/**",
      "**/.continue/**",
      "**/.codeium/**",
      "**/.gemini/**",
      "**/.opencode-agent/**",
      "**/.cline/**"
    ]
  },

  "instructions": [
    ".opencode/rules/*.md"
  ],

  "permission": {
    "bash": "ask",
    "edit": "ask",
    "webfetch": "allow"
  }
}
