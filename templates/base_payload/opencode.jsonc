{
  "$schema": "https://opencode.ai/config.json",
  "model": "google/gemini-3.1-pro",
  "small_model": "anthropic/claude-haiku-3-5",
  "autoupdate": "notify",
  "default_agent": "build",
  "instructions": [
    ".opencode/rules/*.md"
  ],
  "watcher": {
    "ignore": [
      "node_modules/**",
      ".git/**",
      "dist/**",
      "build/**",
      "**/*.log",
      "**/.DS_Store",
      ".opencode/snapshots/**",
      ".hive/**",
      ".swarm/**",
      "_TASKS/**",
      "**/.claude/**",
      "**/.gemini/**",
      "**/.agents/**",
      "**/.agent/**",
      "**/.cursor/**",
      "**/.roocode/**",
      "**/.codebuddy/**",
      "**/.commandcode/**",
      "**/.continue/**",
      "**/.crush/**",
      "**/.factory/**",
      "**/.goose/**",
      "**/.kilocode/**",
      "**/.kiro/**",
      "**/.mcpjam/**",
      "**/.mux/**",
      "**/.neovate/**",
      "**/.openhands/**",
      "**/.pi/**",
      "**/.qoder/**",
      "**/.qwen/**",
      "**/.roo/**",
      "**/.trae/**",
      "**/.windsurf/**",
      "**/.zencoder/**"
    ]
  },
  "permission": {
    "edit": "allow",
    "bash": "ask",
    "webfetch": "allow"
  },
  "compaction": {
    "auto": true,
    "prune": true,
    "reserved": 8000
  },
  "snapshot": true,
  "share": "manual",
  "experimental": {}
}