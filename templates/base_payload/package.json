{
  "name": "opencode-claw-power-user",
  "version": "1.0.0",
  "description": "Hybrid Swarm Architecture with MCP-QA-Gates, .hive Event Sourcing, and Vector Memory",
  "type": "module",
  "scripts": {
    "mcp:start": "node .mcp-server/dist/index.js",
    "mcp:build": "tsc -p .mcp-server/tsconfig.json",
    "biome:check": "biome check --apply .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "security:scan": "semgrep --config=auto --error",
    "qa:full": "npm run biome:check && npm run typecheck && npm run test && npm run security:scan"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20.0.0",
    "better-sqlite3": "^12.6.2",
    "semgrep": "^1.0.0",
    "tree-sitter": "^0.21.0",
    "tree-sitter-typescript": "^0.20.0",
    "typescript": "^5.4.0",
    "vitest": "^1.0.0",
    "zod": "^3.22.0"
  },
  "dependencies": {
    "ollama": "^0.5.0"
  }
}
