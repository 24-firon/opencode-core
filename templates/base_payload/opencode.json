{
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "build",
  "model": "google/gemini-3.1-pro",
  "watcher": {
    "ignore": [
      "**/node_modules/**",
      "**/.opencode/node_modules/**",
      "**/dist/**",
      "projects/**",
      "research/**",
      "Handover/**",
      "plans/**",
      "**/*.lock",
      "package-lock.json",
      ".hive/**",
      ".swarm/**",
      "_TASKS/**"
    ]
  }
}
