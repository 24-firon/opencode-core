{
  "$schema": "https://opencode.ai/config.json",
  "model": "google/gemini-3.1-pro",
  "small_model": "anthropic/claude-haiku-3-5",
  "autoupdate": "notify",
  "default_agent": "build",
  "instructions": [
    ".opencode/rules/*.md",
    "REPO_BRIEFING.md",
    "RULE_REGISTRY.md",
    "docs/DECISION_LOG.md",
    "docs/SESSION_HANDOVER.md",
    "docs/TASK_LIST.md"
  ],
  "watcher": {
    "ignore": [
      "node_modules/**",
      ".git/**",
      "dist/**",
      "build/**",
      "**/*.log",
      "**/.DS_Store",
      ".opencode/snapshots/**",
      "docs/archive/**",
      "docs/learnings/**",
      "templates/base_payload/**",
      "**/.claude/**",
      "**/.gemini/**",
      "**/.agents/**",
      "**/.agent/**",
      "**/.cursor/**",
      "**/.roocode/**",
      "**/.codebuddy/**",
      "**/.commandcode/**",
      "**/.continue/**",
      "**/.crush/**",
      "**/.factory/**",
      "**/.goose/**",
      "**/.kilocode/**",
      "**/.kiro/**",
      "**/.mcpjam/**",
      "**/.mux/**",
      "**/.neovate/**",
      "**/.openhands/**",
      "**/.pi/**",
      "**/.qoder/**",
      "**/.qwen/**",
      "**/.roo/**",
      "**/.trae/**",
      "**/.windsurf/**",
      "**/.zencoder/**"
    ]
  },
  "permission": {
    "edit": "allow",
    "bash": "ask",
    "webfetch": "allow",
    "skill": {
      "*": "deny",
      "agent-batching": "allow",
      "code-review": "allow",
      "code-simplifier": "allow",
      "cleanup-and-harvest": "allow",
      "doc-harvester-protocol": "allow",
      "find-bugs": "allow",
      "git-policy": "allow",
      "handover-protocol": "allow",
      "knowledge-extraction-plugin": "allow",
      "knowledge-router": "allow",
      "memory-shrink": "allow",
      "multi-agent-orchestration": "allow",
      "secrets-management": "allow",
      "security-review": "allow",
      "skill-constructor": "allow",
      "skill-creator": "allow",
      "skill-scanner": "allow",
      "testing-protocols": "allow",
      "three-zone-workflow": "allow",
      "ui-ux-pro-max": "allow",
      "verification-before-completion": "allow",
      "viron-stack-constraints": "allow"
    }
  },
  "compaction": {
    "auto": true,
    "prune": true,
    "reserved": 8000
  },
  "snapshot": true,
  "share": "manual",
  "experimental": {}
}