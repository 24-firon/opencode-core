{
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "build",
  "model": "google/gemini-3.1-pro",
  "watcher": {
    "ignore": [
      "~/.claude/**",
      "~/.gemini/**",
      "~/.agents/**",
      "~/.agent/**",
      "~/.cursor/**",
      "~/.roocode/**",
      "~/.codebuddy/**",
      "~/.commandcode/**",
      "~/.continue/**",
      "~/.crush/**",
      "~/.factory/**",
      "~/.goose/**",
      "~/.kilocode/**",
      "~/.kiro/**",
      "~/.mcpjam/**",
      "~/.mux/**",
      "~/.neovate/**",
      "~/.openhands/**",
      "~/.pi/**",
      "~/.qoder/**",
      "~/.qwen/**",
      "~/.roo/**",
      "~/.trae/**",
      "~/.windsurf/**",
      "~/.zencoder/**",
      "**/.claude/**",
      "**/.gemini/**",
      "**/.agents/**",
      "**/.agent/**",
      "**/.cursor/**",
      "**/.roocode/**",
      "**/.codebuddy/**",
      "**/.commandcode/**",
      "**/.continue/**",
      "**/.crush/**",
      "**/.factory/**",
      "**/.goose/**",
      "**/.kilocode/**",
      "**/.kiro/**",
      "**/.mcpjam/**",
      "**/.mux/**",
      "**/.neovate/**",
      "**/.openhands/**",
      "**/.pi/**",
      "**/.qoder/**",
      "**/.qwen/**",
      "**/.roo/**",
      "**/.trae/**",
      "**/.windsurf/**",
      "**/.zencoder/**",
      "~/.config/opencode/AGENTS.md",
      "~/.config/opencode/skills/**",
      "templates/base_payload/**",
      "node_modules/**",
      "dist/**",
      "**/*.lock"
    ]
  }
}
