{
  "default_agent": "build",
  "ignore_patterns": [
    "~/.claude/**",
    "~/.agents/**",
    "~/.config/opencode/AGENTS.md",
    "~/.config/opencode/skills/**",
    "templates/base_payload/**",
    "node_modules/**",
    "dist/**",
    "**/*.lock"
  ],
  "customInstructions": [
    "{file:./.opencode/rules/00_master_orchestrator_directive.md}",
    "{file:./templates/base_payload/.opencode/rules/01_system_architecture.md}"
  ],
  "context_management": {
    "max_file_read_tokens": 4000,
    "auto_prune_history": true
  },
  "enable_interactive_prompting": true
}
