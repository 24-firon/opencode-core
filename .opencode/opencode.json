    "~/.gemini/**",
    "~/.agents/**",
    "~/.agent/**",
    "~/.cursor/**",
    "~/.roocode/**",
    "~/.codebuddy/**",
    "~/.commandcode/**",
    "~/.continue/**",
    "~/.crush/**",
    "~/.factory/**",
    "~/.goose/**",
    "~/.kilocode/**",
    "~/.kiro/**",
    "~/.mcpjam/**",
    "~/.mux/**",
    "~/.neovate/**",
    "~/.openhands/**",
    "~/.pi/**",
    "~/.qoder/**",
    "~/.qwen/**",
    "~/.roo/**",
    "~/.trae/**",
    "~/.windsurf/**",
    "~/.zencoder/**",
    "**/.claude/**",
    "**/.gemini/**",
    "**/.agents/**",
    "**/.agent/**",
    "**/.cursor/**",
    "**/.roocode/**",
    "**/.codebuddy/**",
    "**/.commandcode/**",
    "**/.continue/**",
    "**/.crush/**",
    "**/.factory/**",
    "**/.goose/**",
    "**/.kilocode/**",
    "**/.kiro/**",
    "**/.mcpjam/**",
    "**/.mux/**",
    "**/.neovate/**",
    "**/.openhands/**",
    "**/.pi/**",
    "**/.qoder/**",
    "**/.qwen/**",
    "**/.roo/**",
    "**/.trae/**",
    "**/.windsurf/**",
    "**/.zencoder/**",
    "~/.config/opencode/AGENTS.md",
    "~/.config/opencode/skills/**",
    "templates/base_payload/**",
    "node_modules/**",
    "dist/**",
    "**/*.lock"
  ],
  "customInstructions": [
    "{file:./.opencode/rules/00_master_orchestrator_directive.md}",
    "{file:./.opencode/rules/01_system_architecture.md}"
  ],
  "context_management": {
    "max_file_read_tokens": 4000,
    "auto_prune_history": true
  },
  "enable_interactive_prompting": true
}
