{
  "default_agent": "build",
  "ignore_patterns": [
    "**/node_modules/**",
    "**/.opencode/node_modules/**",
    "**/dist/**",
    "projects/**",
    "research/**",
    "Handover/**",
    "plans/**",
    "**/*.lock",
    "package-lock.json",
    ".hive/**",
    ".swarm/**",
    "_TASKS/**"
  ],
  "context_management": {
    "max_file_read_tokens": 4000,
    "auto_prune_history": true
  },
  "lsp": {
    "rust": {
      "initialization": {
        "checkOnSave": true,
        "check": {
          "command": "clippy",
          "extraArgs": ["-W", "clippy::pedantic"]
        },
        "diagnostics": {
          "enable": true,
          "enableExperimental": true
        }
      }
    },
    "java": { "disabled": true },
    "csharp": { "disabled": true }
  },
  "mcp": {
    "enabled": true,
    "execution_mode": "sandboxed_scripting"
  },
  "enable_interactive_prompting": true,
  "customInstructions": [
    "{file:./.opencode/rules/01_system_architecture.md}",
    "{file:./.opencode/rules/02_code_and_node_patterns.md}",
    "{file:./.opencode/rules/03_security_and_auth.md}",
    "{file:./.opencode/rules/04_git_workflow.md}",
    "{file:./.opencode/rules/05_subagent_state_retention.md}"
  ],
  "subagents": {
    "explore": {
      "model": "claude-3-5-haiku-20241022"
    }
  }
}
